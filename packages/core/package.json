{
  "name": "@symphony/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./meta": {
      "types": "./dist/meta.d.ts",
      "import": "./dist/meta.js",
      "default": "./dist/meta.js"
    },
    "./tracker": {
      "types": "./dist/tracker.d.ts",
      "import": "./dist/tracker.js",
      "default": "./dist/tracker.js"
    },
    "./github": {
      "types": "./dist/github.d.ts",
      "import": "./dist/github.js",
      "default": "./dist/github.js"
    },
    "./orchestration": {
      "types": "./dist/orchestration.d.ts",
      "import": "./dist/orchestration.js",
      "default": "./dist/orchestration.js"
    },
    "./journal": {
      "types": "./dist/journal.d.ts",
      "import": "./dist/journal.js",
      "default": "./dist/journal.js"
    },
    "./forensics": {
      "types": "./dist/forensics.d.ts",
      "import": "./dist/forensics.js",
      "default": "./dist/forensics.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@symphony/forensics": "workspace:*",
    "@symphony/run-journal": "workspace:*",
    "@symphony/tracker": "workspace:*",
    "esbuild": "^0.27.4",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@symphony/eslint-configs": "workspace:*",
    "@symphony/vitest-configs": "workspace:*",
    "vitest": "^4.1.2"
  }
}
