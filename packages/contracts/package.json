{
  "name": "@symphony/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@symphony/codex-analytics": "workspace:*",
    "@symphony/errors": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@symphony/eslint-configs": "workspace:*",
    "@symphony/vitest-configs": "workspace:*",
    "vitest": "^4.1.2"
  }
}
