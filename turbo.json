{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "tsconfig.tsbuildinfo"
      ]
    },
    "lint": {},
    "test": {
      "dependsOn": [
        "build"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "build"
      ]
    },
    "policy:check": {
      "dependsOn": [
        "^policy:check"
      ]
    },
    "dev": {
      "dependsOn": [
        "^build"
      ],
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  },
  "globalEnv": [
    "NODE_ENV"
  ],
  "globalPassThroughEnv": [
    "GITHUB_TOKEN",
    "GITHUB_WEBHOOK_SECRET",
    "LINEAR_API_KEY",
    "LOG_LEVEL",
    "NEXT_PUBLIC_SYMPHONY_RUNTIME_BASE_URL",
    "PATH",
    "PORT",
    "SYMPHONY_DOCKER_CONTAINER_NAME_PREFIX",
    "SYMPHONY_DOCKER_SHELL",
    "SYMPHONY_DOCKER_WORKSPACE_IMAGE",
    "SYMPHONY_DOCKER_WORKSPACE_PATH",
    "SYMPHONY_DB_FILE",
    "SYMPHONY_GITHUB_STATE_PATH",
    "SYMPHONY_LIVE_DOCKER_VERIFY",
    "SYMPHONY_RUNTIME_BASE_URL",
    "SYMPHONY_SOURCE_REPO",
    "SYMPHONY_TEST_FAKE_DOCKER_LOG",
    "SYMPHONY_WORKSPACE_ROOT",
    "SYMPHONY_TRACKER_KIND",
    "SYMPHONY_LINEAR_ENDPOINT",
    "SYMPHONY_LINEAR_PROJECT_SLUG",
    "SYMPHONY_LINEAR_TEAM_KEY",
    "SYMPHONY_LINEAR_EXCLUDED_PROJECT_IDS",
    "SYMPHONY_LINEAR_ASSIGNEE",
    "SYMPHONY_DISPATCHABLE_STATES",
    "SYMPHONY_TERMINAL_STATES",
    "SYMPHONY_CLAIM_TRANSITION_TO_STATE",
    "SYMPHONY_CLAIM_TRANSITION_FROM_STATES",
    "SYMPHONY_STARTUP_FAILURE_STATE",
    "SYMPHONY_POLL_INTERVAL_MS",
    "SYMPHONY_AGENT_MAX_CONCURRENT",
    "SYMPHONY_AGENT_MAX_TURNS",
    "SYMPHONY_AGENT_MAX_RETRY_BACKOFF_MS",
    "SYMPHONY_CODEX_COMMAND",
    "SYMPHONY_CODEX_THREAD_SANDBOX",
    "SYMPHONY_CODEX_TURN_TIMEOUT_MS",
    "SYMPHONY_CODEX_READ_TIMEOUT_MS",
    "SYMPHONY_CODEX_STALL_TIMEOUT_MS",
    "SYMPHONY_HOOK_TIMEOUT_MS",
    "SYMPHONY_SERVER_HOST",
    "SYMPHONY_GITHUB_REPOSITORY",
    "SYMPHONY_GITHUB_WEBHOOK_SECRET",
    "SYMPHONY_GITHUB_API_TOKEN",
    "SYMPHONY_GITHUB_ALLOWED_REVIEW_LOGINS",
    "SYMPHONY_GITHUB_ALLOWED_REWORK_LOGINS"
  ],
  "globalDependencies": [
    "packages/typescript-configs/tsconfig.base.json",
    "packages/eslint-configs/eslint.config.ts",
    "packages/eslint-configs/src/**"
  ]
}
