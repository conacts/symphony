{
  "name": "@symphony/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint .",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:docker-live": "SYMPHONY_LIVE_DOCKER_VERIFY=1 vitest run src/core/codex-agent-runtime.live-docker.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@symphony/env": "workspace:*",
    "@symphony/db": "workspace:*",
    "@symphony/errors": "workspace:*",
    "@symphony/forensics": "workspace:*",
    "@symphony/github-review": "workspace:*",
    "@symphony/logger": "workspace:*",
    "@symphony/contracts": "workspace:*",
    "@symphony/core": "workspace:*",
    "@symphony/run-journal": "workspace:*",
    "@symphony/runtime-contract": "workspace:*",
    "@symphony/tracker": "workspace:*",
    "@symphony/workspace": "workspace:*",
    "@hono/node-server": "^1.19.12",
    "@hono/node-ws": "^1.3.0",
    "hono": "^4.11.4"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "@symphony/eslint-configs": "workspace:*",
    "@symphony/test-support": "workspace:*",
    "@symphony/vitest-configs": "workspace:*",
    "tsx": "^4.21.0",
    "vitest": "^4.1.2",
    "ws": "^8.20.0"
  }
}
